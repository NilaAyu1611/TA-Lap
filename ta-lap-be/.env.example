# =============================================================================

# TA-LAP Backend — Environment Variables

# Salin file ini ke `.env` lalu isi nilai yang sesuai.

# =============================================================================



DATABASE_URL="mysql://root:@localhost:3306/talap_db"

JWT_SECRET=ganti-dengan-secret-panjang-dan-acak

PORT=3002



# -----------------------------------------------------------------------------

# FRONTEND URL — untuk link reset password di email

# -----------------------------------------------------------------------------

FRONTEND_URL=http://localhost:3000



# -----------------------------------------------------------------------------

# GOOGLE SIGN-IN — OAuth Client ID (Web application)

# Console: https://console.cloud.google.com/apis/credentials

# Authorized JavaScript origins: http://localhost:3000

# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=""



# -----------------------------------------------------------------------------

# EMAIL SMTP — Reset password & notifikasi email (Gmail App Password atau SMTP lain)
# Notifikasi booking/pembayaran dikirim otomatis jika SMTP aktif dan toggle di Admin Settings ON

# -----------------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_SECURE=false

SMTP_USER=""

SMTP_PASS=""

MAIL_FROM="TA-LAP <noreply@example.com>"



# -----------------------------------------------------------------------------

# WEB PUSH — Notifikasi popup browser (VAPID keys)

# Generate: cd ta-lap-be && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"

# -----------------------------------------------------------------------------

VAPID_PUBLIC_KEY=""

VAPID_PRIVATE_KEY=""

VAPID_SUBJECT="mailto:you@example.com"



# -----------------------------------------------------------------------------

# Dashboard Sandbox: https://dashboard.sandbox.midtrans.com

# Langkah: Login → Settings → Access Keys → copy Server Key & Client Key

# -----------------------------------------------------------------------------

MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxx"

MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxx"

MIDTRANS_IS_PRODUCTION=false

MIDTRANS_SNAP_SHOW_ALL=false



# -----------------------------------------------------------------------------

# TOMTOM MAPS — Autocomplete lokasi (Search API)

# Daftar: https://developer.tomtom.com/ → buat app → copy API Key

# Aktifkan: Search API

# -----------------------------------------------------------------------------

TOMTOM_API_KEY=""

