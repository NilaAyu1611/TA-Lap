generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUM
//////////////////////

enum Role {
  admin
  owner
  user
}

enum JenisLapangan {
  badminton
  futsal
}

enum StatusPesanan {
  pending
  dibayar
  selesai
}

enum StatusPembayaran {
  menunggu
  sukses
  gagal
}

//////////////////////
// MODEL
//////////////////////

model User {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(user)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lapangans Lapangan[] @relation("OwnerLapangan")
  pesanans  Pesanan[]
}

model Lapangan {
  id        BigInt   @id @default(autoincrement())
  owner_id  BigInt?
  nama      String
  jenis     JenisLapangan
  harga     Decimal   @default(0)
  gambar    String?
  status    Boolean   @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner     User?      @relation("OwnerLapangan", fields: [owner_id], references: [id])
  pesanans  Pesanan[]
}

model Pesanan {
  id              BigInt         @id @default(autoincrement())
  user_id         BigInt
  lapangan_id     BigInt
  tanggal_booking DateTime
  jam_mulai       DateTime
  jam_selesai     DateTime
  status          StatusPesanan  @default(pending)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  user      User     @relation(fields: [user_id], references: [id])
  lapangan  Lapangan @relation(fields: [lapangan_id], references: [id])
  pembayaran Pembayaran?
}

model Pembayaran {
  id            BigInt           @id @default(autoincrement())
  pesanan_id    BigInt           @unique
  metode        String
  total_bayar   Int
  status        StatusPembayaran @default(menunggu)
  tanggal_bayar DateTime?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  pesanan   Pesanan @relation(fields: [pesanan_id], references: [id])
}